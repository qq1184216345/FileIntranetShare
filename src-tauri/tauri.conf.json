{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FileShare",
  "version": "0.1.2",
  "identifier": "com.fileshare.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FileShare 文件共享(局域网)",
        "width": 880,
        "height": 680,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "局域网文件 / 文本共享工具",
    "longDescription": "在局域网内一键启动 HTTP 服务，同网段浏览器即可访问上传文件、分享文本。支持密码保护、大文件分片续传、二维码快速连接、剪贴板一键分享、系统托盘常驻、记录持久化。",
    "copyright": "Copyright © 2026 FileShare Contributors",
    "publisher": "FileShare",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": false,
        "compression": "lzma",
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {}
}
